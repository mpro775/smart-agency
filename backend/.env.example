# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-agency?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d

# Optional one-time admin seeding
SEED_ADMIN=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

# Cloudflare R2 / S3-compatible upload storage (optional at startup)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=

# n8n Webhook URL (Optional)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/leads

# Frontend URLs (for CORS) - comma separated for multiple origins
FRONTEND_URL=http://localhost:5173,https://smartagency-ye.com,https://www.smartagency-ye.com

# Deployment hosts used by the unified Docker Compose stack
FRONTEND_HOST=smartagency-ye.com
API_HOST=api.smartagency-ye.com
TRAEFIK_NETWORK=platform-network
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
