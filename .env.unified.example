PROJECT_SLUG=smart-agency
NODE_ENV=production

APP_PORT=3000
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/smart-agency

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d

SEED_ADMIN=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

FRONTEND_URL=https://smartagency-ye.com
FRONTEND_HOST=smartagency-ye.com
API_HOST=api.smartagency-ye.com
VITE_API_URL=/api
TRAEFIK_NETWORK=platform-network
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
N8N_WEBHOOK_URL=https://n8n.smartagency-ye.com/webhook/leads

R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=
